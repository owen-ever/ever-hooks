    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "globals": "^15.0.0",
    "husky": "^9.1.6",
    "prettier": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typedoc": "^0.26.0",
    "typescript": "^5.5.0",
